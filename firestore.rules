rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scrapers
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - subreddit: string (required, max 50 chars)
    //   - keyword: string (required, max 100 chars)
    //   - intervalMinutes: number (required, > 0)
    //   - status: string (required, 'active' or 'paused')
    //   - createdAt: timestamp (required, immutable)
    //   - lastRunAt: timestamp (optional)
    //   - userId: string (required, immutable, must match auth.uid)
    //
    // Collection: leads
    // Document ID: auto-generated
    // Fields:
    //   - scraperId: string (required, max 50 chars)
    //   - platform: string (optional, 'reddit', 'hackernews', etc.)
    //   - target: string (optional, max 100 chars)
    //   - subreddit: string (optional, max 50 chars)
    //   - city: string (optional, max 50 chars)
    //   - category: string (optional, max 50 chars)
    //   - keyword: string (required, max 100 chars)
    //   - postTitle: string (required, max 500 chars)
    //   - postUrl: string (required, max 500 chars)
    //   - postAuthor: string (required, max 100 chars)
    //   - postContent: string (optional, max 10000 chars)
    //   - score: number (optional, 1-10)
    //   - reason: string (optional, max 2000 chars)
    //   - status: string (optional, 'new', 'sent', 'rejected')
    //   - whatsappMessage: string (optional, max 5000 chars)
    //   - email: string (optional, max 200 chars)
    //   - phone: string (optional, max 100 chars)
    //   - location: string (optional, max 500 chars)
    //   - company: string (optional, max 500 chars)
    //   - createdAt: timestamp (required, immutable)
    //   - userId: string (required, immutable, must match auth.uid)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !('field' in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidScraperCreate() {
      let allowedFields = ['name', 'subreddit', 'platform', 'target', 'city', 'category', 'keyword', 'leadDefinition', 'clientName', 'clientPhone', 'idealCustomerProfile', 'intervalMinutes', 'status', 'createdAt', 'lastRunAt', 'userId', 'icon', 'portalToken', 'trialLimit', 'isPaid', 'totalPushedLeads', 'totalClientClicks'];
      let requiredFields = ['name', 'keyword', 'intervalMinutes', 'status', 'createdAt', 'userId'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             validStringLength('name', 1, 100) &&
             (!('subreddit' in request.resource.data) || validStringLength('subreddit', 1, 100)) &&
             (!('platform' in request.resource.data) || request.resource.data.platform in ['reddit', 'hackernews', 'stackoverflow', 'craigslist']) &&
             (!('target' in request.resource.data) || validStringLength('target', 0, 200)) &&
             (!('city' in request.resource.data) || validStringLength('city', 1, 100)) &&
             (!('category' in request.resource.data) || validStringLength('category', 1, 50)) &&
             validStringLength('keyword', 1, 500) &&
             (!('leadDefinition' in request.resource.data) || validStringLength('leadDefinition', 1, 2000)) &&
             (!('clientName' in request.resource.data) || validStringLength('clientName', 1, 100)) &&
             (!('clientPhone' in request.resource.data) || validStringLength('clientPhone', 1, 50)) &&
             (!('idealCustomerProfile' in request.resource.data) || validStringLength('idealCustomerProfile', 1, 5000)) &&
             request.resource.data.intervalMinutes is number &&
             request.resource.data.intervalMinutes > 0 &&
             request.resource.data.status in ['active', 'paused'] &&
             request.resource.data.createdAt is timestamp &&
             (!('lastRunAt' in request.resource.data) || request.resource.data.lastRunAt is timestamp) &&
             (!('icon' in request.resource.data) || validStringLength('icon', 1, 50)) &&
             request.resource.data.userId == request.auth.uid;
    }

    function isValidScraperUpdate() {
      let allowedFields = ['name', 'subreddit', 'platform', 'target', 'city', 'category', 'keyword', 'leadDefinition', 'clientName', 'clientPhone', 'idealCustomerProfile', 'intervalMinutes', 'status', 'createdAt', 'lastRunAt', 'userId', 'icon', 'portalToken', 'trialLimit', 'isPaid', 'totalPushedLeads', 'totalClientClicks'];
      let requiredFields = ['name', 'keyword', 'intervalMinutes', 'status', 'createdAt', 'userId'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             validStringLength('name', 1, 100) &&
             (!('subreddit' in request.resource.data) || validStringLength('subreddit', 1, 100)) &&
             (!('platform' in request.resource.data) || request.resource.data.platform in ['reddit', 'hackernews', 'stackoverflow', 'craigslist']) &&
             (!('target' in request.resource.data) || validStringLength('target', 0, 200)) &&
             (!('city' in request.resource.data) || validStringLength('city', 1, 100)) &&
             (!('category' in request.resource.data) || validStringLength('category', 1, 50)) &&
             validStringLength('keyword', 1, 500) &&
             (!('leadDefinition' in request.resource.data) || validStringLength('leadDefinition', 1, 2000)) &&
             (!('clientName' in request.resource.data) || validStringLength('clientName', 1, 100)) &&
             (!('clientPhone' in request.resource.data) || validStringLength('clientPhone', 1, 50)) &&
             (!('idealCustomerProfile' in request.resource.data) || validStringLength('idealCustomerProfile', 1, 5000)) &&
             request.resource.data.intervalMinutes is number &&
             request.resource.data.intervalMinutes > 0 &&
             request.resource.data.status in ['active', 'paused'] &&
             (!('lastRunAt' in request.resource.data) || request.resource.data.lastRunAt is timestamp) &&
             (!('icon' in request.resource.data) || validStringLength('icon', 1, 50));
    }

    function isValidLead() {
      let allowedFields = ['scraperId', 'subreddit', 'platform', 'target', 'city', 'category', 'keyword', 'postTitle', 'postUrl', 'postAuthor', 'postContent', 'score', 'reason', 'status', 'whatsappMessage', 'email', 'phone', 'location', 'company', 'createdAt', 'userId', 'pushedToPortal', 'clientViewCount', 'clientFeedback'];
      let requiredFields = ['scraperId', 'keyword', 'postTitle', 'postUrl', 'postAuthor', 'createdAt', 'userId'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             validStringLength('scraperId', 1, 50) &&
             (!('subreddit' in request.resource.data) || validStringLength('subreddit', 1, 50)) &&
             (!('platform' in request.resource.data) || request.resource.data.platform in ['reddit', 'hackernews', 'stackoverflow', 'craigslist']) &&
             (!('target' in request.resource.data) || validStringLength('target', 0, 100)) &&
             (!('city' in request.resource.data) || validStringLength('city', 1, 50)) &&
             (!('category' in request.resource.data) || validStringLength('category', 1, 50)) &&
             validStringLength('keyword', 1, 500) &&
             validStringLength('postTitle', 1, 500) &&
             validStringLength('postUrl', 1, 500) &&
             validStringLength('postAuthor', 1, 100) &&
             (!('postContent' in request.resource.data) || validStringLength('postContent', 0, 10000)) &&
             (!('score' in request.resource.data) || (request.resource.data.score is number && request.resource.data.score >= 1 && request.resource.data.score <= 10)) &&
             (!('reason' in request.resource.data) || validStringLength('reason', 0, 2000)) &&
             (!('status' in request.resource.data) || request.resource.data.status in ['new', 'viewed', 'sent', 'rejected']) &&
             (!('whatsappMessage' in request.resource.data) || validStringLength('whatsappMessage', 0, 5000)) &&
             (!('email' in request.resource.data) || request.resource.data.email == null || validStringLength('email', 1, 200)) &&
             (!('phone' in request.resource.data) || request.resource.data.phone == null || validStringLength('phone', 1, 100)) &&
             (!('location' in request.resource.data) || request.resource.data.location == null || validStringLength('location', 1, 500)) &&
             (!('company' in request.resource.data) || request.resource.data.company == null || validStringLength('company', 1, 500)) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /scrapers/{scraperId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidScraperCreate();
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid && 
                    request.resource.data.userId == resource.data.userId && (
                      // Full update (status, keyword, etc.)
                      (
                        isValidScraperUpdate() &&
                        request.resource.data.createdAt == resource.data.createdAt
                      ) ||
                      // Lightweight bypass: background engine updates lastRunAt only
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastRunAt']) ||
                      // Lightweight bypass: portal management (deploy/kill/extend)
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['portalToken']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['portalToken', 'trialLimit', 'isPaid']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['trialLimit']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPaid']) ||
                      // Lightweight bypass: engagement counters
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPushedLeads']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalClientClicks']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPushedLeads', 'totalClientClicks'])
                    );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /leads/{leadId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidLead();
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid && 
                    request.resource.data.userId == resource.data.userId && (
                      (
                        isValidLead() &&
                        request.resource.data.createdAt == resource.data.createdAt
                      ) ||
                      // Lightweight bypass: partial UI updates
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pushedToPortal', 'status']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientViewCount']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientFeedback'])
                    );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /logs/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.createdAt is timestamp;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}

{
  "entities": {
    "Scraper": {
      "title": "Scraper",
      "description": "A Reddit scraper configuration",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the scraper"
        },
        "subreddit": {
          "type": "string",
          "description": "Target subreddit without the r/ prefix"
        },
        "keyword": {
          "type": "string",
          "description": "Keyword to look for in posts"
        },
        "intervalMinutes": {
          "type": "number",
          "description": "Interval in minutes to run the scraper"
        },
        "leadDefinition": {
          "type": "string",
          "description": "Custom definition of what a perfect lead looks like for this scraper"
        },
        "status": {
          "type": "string",
          "enum": ["active", "paused"],
          "description": "Current status of the scraper"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the scraper was created"
        },
        "lastRunAt": {
          "type": "timestamp",
          "description": "When the scraper last ran"
        },
        "userId": {
          "type": "string",
          "description": "Owner of the scraper"
        }
      },
      "required": ["name", "subreddit", "keyword", "intervalMinutes", "status", "createdAt", "userId"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A lead generated from a social media post",
      "type": "object",
      "properties": {
        "scraperId": {
          "type": "string",
          "description": "ID of the scraper that found this lead"
        },
        "platform": {
          "type": "string",
          "description": "Platform where the lead was found (reddit or stackoverflow)"
        },
        "target": {
          "type": "string",
          "description": "Target source (subreddit, HN category, etc.)"
        },
        "subreddit": {
          "type": "string",
          "description": "Subreddit where the lead was found (legacy field)"
        },

        "keyword": {
          "type": "string",
          "description": "Keyword that matched"
        },
        "postTitle": {
          "type": "string",
          "description": "Title of the post"
        },
        "postUrl": {
          "type": "string",
          "description": "URL of the post"
        },
        "postAuthor": {
          "type": "string",
          "description": "Author of the post"
        },
        "postContent": {
          "type": "string",
          "description": "Content of the post"
        },
        "score": {
          "type": "number",
          "description": "AI generated score (1-10)"
        },
        "reason": {
          "type": "string",
          "description": "AI generated reason for the score"
        },
        "status": {
          "type": "string",
          "enum": ["new", "sent", "rejected"],
          "description": "Status of the lead"
        },
        "whatsappMessage": {
          "type": "string",
          "description": "Drafted WhatsApp message"
        },
        "email": {
          "type": "string",
          "description": "Extracted email address"
        },
        "phone": {
          "type": "string",
          "description": "Extracted phone number"
        },
        "location": {
          "type": "string",
          "description": "Extracted location"
        },
        "company": {
          "type": "string",
          "description": "Extracted company name"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the lead was found and saved"
        },
        "userId": {
          "type": "string",
          "description": "Owner of the lead"
        }
      },
      "required": ["scraperId", "keyword", "postTitle", "postUrl", "postAuthor", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/scrapers/{scraperId}": {
      "schema": {
        "$ref": "#/entities/Scraper"
      },
      "description": "Stores scraper configurations"
    },
    "/leads/{leadId}": {
      "schema": {
        "$ref": "#/entities/Lead"
      },
      "description": "Stores leads generated by scrapers"
    }
  }
}
